# =============================================================================
# Carmelis Studio — environment configuration
# =============================================================================
# Copy this file to `.env.local` (which is gitignored) and fill in real values.
# In production, set the same variables in your host's environment dashboard
# (Vercel → Project Settings → Environment Variables).
# =============================================================================

# ----- Supabase ---------------------------------------------------------------
# Project Settings → API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key. Server-only — NEVER ship in a NEXT_PUBLIC_* var. Used by
# server actions for admin writes and by the SMS worker to drain the queue.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----- Site URL ---------------------------------------------------------------
# Origin used to construct customer-facing manage URLs in SMS bodies.
# Dev:  http://localhost:3001  (or whatever port `npm run dev` chooses)
# Prod: https://carmelis.co.il
# Falls back to https://carmelis.co.il if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ----- Barber calendar feed (Phase 4) -----------------------------------------
# Opaque UUID gating the public iCalendar feed at
# /api/calendar/<BARBER_CALENDAR_TOKEN>. Generate a fresh UUID per environment;
# never reuse the dev value in prod.
#   node -e "console.log(crypto.randomUUID())"
BARBER_CALENDAR_TOKEN=

# ----- SMS worker secret (Phase 2) --------------------------------------------
# Bearer token gating /api/notifications/run. The route accepts EITHER:
#   - NOTIFICATIONS_WORKER_SECRET (manual triggers, curl, ad-hoc drains)
#   - CRON_SECRET                 (Vercel Cron sends this automatically when
#                                  set in the Vercel project env)
# In production on Vercel, set both to the same long random string for
# simplicity, OR set only CRON_SECRET if you don't need manual triggers.
# Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NOTIFICATIONS_WORKER_SECRET=
# CRON_SECRET=  (Vercel-only; not used in dev)

# ----- Inforu SMS provider (Phase 2) ------------------------------------------
# Sign up at inforu.co.il. Sender-ID has a 2-5 day approval lead. The
# originating server's IP must also be allowlisted in the Inforu portal —
# without that, sends fail with StatusId:-2 "Authentication failed or illegal
# IP address" even with valid creds. See lib/sms/inforu.ts for the full
# adapter contract (probed against capi.inforu.co.il).
INFORU_USERNAME=
INFORU_API_TOKEN=
INFORU_SENDER=
# Optional override; defaults to https://capi.inforu.co.il/api/v2/SMS/SendSms
# INFORU_API_URL=

# ----- Google Calendar integration (Phase 7) ----------------------------------
# OAuth 2.0 client credentials. Set up:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create a new project (or reuse one).
#   3. Enable the Google Calendar API.
#   4. Configure OAuth consent screen (External, scope: ../auth/calendar.events).
#   5. Create OAuth client → Web application.
#   6. Add authorised redirect URIs:
#        http://localhost:3001/api/auth/google/callback   (dev)
#        https://carmelis.co.il/api/auth/google/callback  (prod)
#   7. Copy client id + secret here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# ----- Public URLs surfaced by the site (defaults shown) ----------------------
NEXT_PUBLIC_WIX_BOOKING_URL=https://www.carmelis-studio.com/book-online
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/carmelis_studio
NEXT_PUBLIC_BITPAY_URL=https://www.bitpay.co.il
