# Supabase credentials — get these from Supabase Dashboard → Project Settings → API
# Copy this file to `.env.local` and fill in real values. `.env.local` is gitignored.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional public URLs referenced by the site (defaults shown)
NEXT_PUBLIC_WIX_BOOKING_URL=https://www.carmelis-studio.com/book-online
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/carmelis_studio
NEXT_PUBLIC_BITPAY_URL=https://www.bitpay.co.il
